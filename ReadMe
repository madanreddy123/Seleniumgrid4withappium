
#### Go to the Folder Directory selenium from the terminal and run each of the cmd command mentioned in the txt file from the selenium folder


import io.restassured.RestAssured;
import io.restassured.response.Response;
import static io.restassured.RestAssured.*;

public class XrayApiExample {

    public static void main(String[] args) {
        // Set base URI
        RestAssured.baseURI = "https://xray.cloud.getxray.app";

        // Step 1: Get Bearer Token
        String clientId = "your-client-id";
        String clientSecret = "your-client-secret";

        String token = given()
            .header("Content-Type", "application/json")
            .body("{ \"client_id\": \"" + clientId + "\", \"client_secret\": \"" + clientSecret + "\" }")
        .when()
            .post("/api/v2/authenticate")
        .then()
            .statusCode(200)
            .extract()
            .asString()
            .replace("\"", ""); // Remove quotes from token

        System.out.println("Bearer Token: " + token);

        // Step 2: Use token to get test case details
        String testKey = "TEST-123"; // Replace with a real test case key

        Response testDetailsResponse = given()
            .header("Authorization", "Bearer " + token)
            .header("Accept", "application/json")
        .when()
            .get("/api/v2/test/" + testKey)
        .then()
            .statusCode(200)
            .extract()
            .response();

        // Print test details
        System.out.println("Test Case Response: " + testDetailsResponse.asPrettyString());
    }
}