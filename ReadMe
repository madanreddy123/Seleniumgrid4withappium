
#### Go to the Folder Directory selenium from the terminal and run each of the cmd command mentioned in the txt file from the selenium 



import io.restassured.RestAssured;
import org.json.JSONArray;
import org.json.JSONObject;

import static io.restassured.RestAssured.given;

public class XrayExecution {

    public static void main(String[] args) {
        String token = "your_bearer_token"; // Replace with your token
        String executionKey = "PROJECT-123";
        String testCaseKey = "PROJECT-456";

        // Build the JSON object
        JSONObject testCase = new JSONObject();
        testCase.put("testKey", testCaseKey);
        testCase.put("status", "PASSED");

        JSONArray tests = new JSONArray();
        tests.put(testCase);

        JSONObject body = new JSONObject();
        body.put("testExecutionKey", executionKey);
        body.put("tests", tests);

        // Send the request
        RestAssured.baseURI = "https://xray.cloud.getxray.app/api/v2";

        given()
            .header("Content-Type", "application/json")
            .header("Authorization", "Bearer " + token)
            .body(body.toString())
        .when()
            .post("/import/execution")
        .then()
            .statusCode(200);
    }
}