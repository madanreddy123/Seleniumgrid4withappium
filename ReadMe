
#### Go to the Folder Directory selenium from the terminal and run each of the cmd command mentioned in the txt file from the selenium 



import io.restassured.RestAssured;
import io.restassured.response.Response;

import static io.restassured.RestAssured.*;

public class XrayApiWithRestAssuredProxy {

    public static void main(String[] args) {

        // Step 1: Set Base URI
        RestAssured.baseURI = "https://xray.cloud.getxray.app";

        // Step 2: Set Proxy using IP and Port
        RestAssured.proxy("192.168.1.100", 8080); // Replace with your proxy IP and port

        // Step 3: Authenticate using client_id and client_secret
        String clientId = "your-client-id";         // Replace with actual Xray client ID
        String clientSecret = "your-client-secret"; // Replace with actual secret

        String authPayload = String.format(
            "{ \"client_id\": \"%s\", \"client_secret\": \"%s\" }",
            clientId, clientSecret
        );

        String token = given()
            .header("Content-Type", "application/json")
            .body(authPayload)
        .when()
            .post("/api/v2/authenticate")
        .then()
            .statusCode(200)
            .extract()
            .asString()
            .replace("\"", "");

        System.out.println("Bearer Token: " + token);

        // Step 4: Get Test Case Details using the Bearer Token
        String testKey = "TEST-123"; // Replace with your actual test key

        Response response = given()
            .header("Authorization", "Bearer " + token)
            .header("Accept", "application/json")
        .when()
            .get("/api/v2/test/" + testKey)
        .then()
            .statusCode(200)
            .extract()
            .response();

        System.out.println("Test Case Response:\n" + response.asPrettyString());
    }
}